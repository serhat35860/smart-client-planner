generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum ClientStatus {
  ACTIVE
  PASSIVE
  POTENTIAL
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
}

enum TaskStatus {
  PENDING
  DONE
  FAILED
}

enum WorkspaceRole {
  ADMIN
  USER
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  username  String?  @unique
  passwordHash String
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workspaceMember WorkspaceMember?
  clientsCreated  Client[] @relation("ClientCreatedBy")
  clientsUpdated  Client[] @relation("ClientUpdatedBy")
  notesCreated    Note[]   @relation("NoteCreatedBy")
  notesUpdated    Note[]   @relation("NoteUpdatedBy")
  tasksCreated    Task[]   @relation("TaskCreatedBy")
  tasksUpdated    Task[]   @relation("TaskUpdatedBy")
  tasksAssigned   Task[]   @relation("TaskAssignee")
  tagsCreated     Tag[]    @relation("TagCreatedBy")
  noteMentions    NoteUserMention[]
  taskMentions    TaskUserMention[]
  sessions        UserSession[]
  auditEvents     AuditEvent[] @relation("AuditActor")

}

/** Paylaşılan ekip alanı: müşteriler, notlar, görevler workspace’e bağlıdır. */
model Workspace {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members WorkspaceMember[]
  clients Client[]
  notes   Note[]
  tasks   Task[]
  tags    Tag[]
  invites WorkspaceInvite[]
  auditEvents AuditEvent[]
}

model UserSession {
  id        String    @id @default(cuid())
  userId    String
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())
  lastSeenAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
  @@index([revokedAt])
}

model AuditEvent {
  id          String   @id @default(cuid())
  workspaceId String?
  actorUserId String?
  eventType   String
  entityType  String?
  entityId    String?
  ipAddress   String?
  userAgent   String?
  metaJson    Json?
  createdAt   DateTime @default(now())

  workspace Workspace? @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  actor     User?      @relation("AuditActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([workspaceId, createdAt])
  @@index([actorUserId, createdAt])
  @@index([eventType, createdAt])
}

/** Her kullanıcı tek bir workspace’e üyedir (MVP). */
model WorkspaceMember {
  id          String        @id @default(cuid())
  workspaceId String
  userId      String        @unique
  role        WorkspaceRole @default(USER)
  /** Pasif üye oturum açamaz ve çalışma alanına erişemez. */
  isActive    Boolean       @default(true)
  createdAt   DateTime      @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
}

model WorkspaceInvite {
  id          String   @id @default(cuid())
  workspaceId String
  token       String   @unique
  expiresAt   DateTime
  createdAt   DateTime @default(now())
  createdById String

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
}

model Client {
  id              String       @id @default(cuid())
  fileNumber      String?
  companyName     String
  contactPerson   String
  phone           String
  /** Ek yetkili kişiler: [{ "name", "phone", "jobTitle"? }] */
  additionalContacts Json?
  email           String
  sector          String?
  generalNotes    String?
  status          ClientStatus @default(POTENTIAL)
  workspaceId     String
  createdByUserId String?
  updatedByUserId String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdBy User?     @relation("ClientCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  updatedBy User?     @relation("ClientUpdatedBy", fields: [updatedByUserId], references: [id], onDelete: SetNull)
  notes     Note[]
  tasks     Task[]

  @@index([workspaceId, companyName])
  @@unique([workspaceId, fileNumber])
  @@index([createdByUserId])
  @@index([updatedByUserId])
}

model Note {
  id                  String    @id @default(cuid())
  title               String?
  content             String
  nextActionDate      DateTime?
  remindBeforeMinutes Int?
  color               String    @default("yellow")
  workspaceId         String
  clientId            String?
  createdByUserId     String?
  updatedByUserId     String?
  /** Ekleyen dışında en az bir kullanıcı kayıt yaptıysa true (ekleyen sonra tekrar düzenlese de kalır). */
  editedByOtherMember Boolean   @default(false)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  client    Client?   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  createdBy User?     @relation("NoteCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  updatedBy User?     @relation("NoteUpdatedBy", fields: [updatedByUserId], references: [id], onDelete: SetNull)
  task      Task?
  tags      NoteTag[]
  mentions  NoteUserMention[]

  @@index([clientId, createdAt])
  @@index([workspaceId, createdAt])
  @@index([createdByUserId])
  @@index([updatedByUserId])
}

model Task {
  id                  String       @id @default(cuid())
  title               String
  content             String?
  deadline            DateTime
  remindBeforeMinutes Int?
  priority            TaskPriority @default(MEDIUM)
  color               String       @default("yellow")
  status              TaskStatus   @default(PENDING)
  notCompletedReason  String?
  /** Görev tamamlanırken kaydedilen gelişmeler / notlar. */
  completionNotes     String?
  workspaceId         String
  clientId            String?
  assigneeUserId      String?
  acceptedAt          DateTime?
  noteId              String?      @unique
  createdByUserId     String?
  updatedByUserId     String?
  editedByOtherMember Boolean      @default(false)
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  client    Client?   @relation(fields: [clientId], references: [id], onDelete: SetNull)
  note      Note?     @relation(fields: [noteId], references: [id], onDelete: SetNull)
  createdBy User?     @relation("TaskCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  updatedBy User?     @relation("TaskUpdatedBy", fields: [updatedByUserId], references: [id], onDelete: SetNull)
  assignee  User?     @relation("TaskAssignee", fields: [assigneeUserId], references: [id], onDelete: SetNull)
  mentions  TaskUserMention[]

  @@index([workspaceId, deadline, status])
  @@index([assigneeUserId, acceptedAt])
  @@index([createdByUserId])
  @@index([updatedByUserId])
}

model Tag {
  id              String    @id @default(cuid())
  name            String
  workspaceId     String
  createdByUserId String?
  createdAt       DateTime  @default(now())
  noteTags        NoteTag[]

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdBy User?     @relation("TagCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@unique([workspaceId, name])
  @@index([workspaceId])
  @@index([createdByUserId])
}

model NoteTag {
  noteId String
  tagId  String

  note Note @relation(fields: [noteId], references: [id], onDelete: Cascade)
  tag  Tag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([noteId, tagId])
  @@index([tagId])
}

/** Not üzerinde ekip üyesi etiketleme (@mention). */
model NoteUserMention {
  noteId String
  userId String

  note Note @relation(fields: [noteId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([noteId, userId])
  @@index([userId])
}

/** Görevde ekip üyesi etiketleme. */
model TaskUserMention {
  taskId String
  userId String

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([taskId, userId])
  @@index([userId])
}

