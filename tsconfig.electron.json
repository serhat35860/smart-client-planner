{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "commonjs",
    "target": "ES2022",
    "lib": ["ES2022", "DOM"],
    "outDir": "dist-electron",
    "noEmit": false,
    "sourceMap": true,
    "moduleResolution": "node",
    "types": ["node", "electron"]
  },
  "include": ["electron/**/*.ts"]
}
